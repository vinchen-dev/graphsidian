#!/usr/bin/env bash
set -euo pipefail

# graphify-obsidian-init — wire the two-layer knowledge system (Obsidian vault +
# graphify graph) onto a project. Idempotent: safe to re-run.
#
# Does the deterministic, version-fragile parts:
#   1. scaffold the vault (folders + hub stamped with format_version + setup_version,
#      a git-hook gotcha note, + Home.md link)
#   2. install the graphify post-commit hook (auto-rebuild graph.json)
#   3. idempotently patch that hook to re-export the graph into Obsidian
# The one-time semantic build (docs → LLM) is left to `/graphify` inside Claude.

# Vault location. Resolved from the running Obsidian instance via the obsidian CLI
# (always current, even after the vault moves); falls back to ~/Obsidian/Claude if
# Obsidian isn't running or the CLI is unavailable.
VAULT_BASE="$(obsidian vault="Claude" eval code="app.vault.adapter.basePath" 2>/dev/null | sed 's/^=> //')"
[ -n "$VAULT_BASE" ] && [ -f "$VAULT_BASE/FORMAT.md" ] || VAULT_BASE="$HOME/Obsidian/Claude"

usage() {
  cat <<EOF
Usage: graphify-obsidian-init <project> [repo-path]

  <project>    project name (vault folder + hub name), e.g. finance-ai
  [repo-path]  path to the code repo (default: current directory)

Idempotent. After it runs, open Claude in the repo and run /graphify once for
the initial build.
EOF
}

[ $# -lt 1 ] && { usage; exit 1; }
case "$1" in -h|--help) usage; exit 0 ;; esac

PROJECT="$1"
REPO="${2:-$PWD}"
REPO="$(cd "$REPO" 2>/dev/null && pwd -P)" || { echo "repo path not found: ${2:-$PWD}" >&2; exit 1; }
VAULT="$VAULT_BASE/Projects/$PROJECT"
AUTO_DIR="$VAULT/graphify-auto/"

echo "Project : $PROJECT"
echo "Repo    : $REPO"
echo "Vault   : $VAULT"
echo

# 1. Vault scaffolding ------------------------------------------------------
mkdir -p "$VAULT"/{specs,decisions,knowledge,reference,plans,investigations}
echo "✓ vault folders ready"

HUB="$VAULT/$PROJECT.md"
if [ ! -f "$HUB" ]; then
  cat > "$HUB" <<EOF
---
tags:
  - project
project: $PROJECT
status: active
repo: $REPO
format_version: "2.2.0"
setup_version: "1.3.0"
---

# $PROJECT

<One-paragraph summary.>

**Stack:** <tech · tech · tech>

## Notes

### Knowledge (\`knowledge/\`)
- [[git-hook-graphify]] — post-commit/checkout hook keeps the graph fresh; \`git pull\` needs \`graphify update .\`; re-register with \`graphify hook install\`.

### Investigations (\`investigations/\`)

### Graph (\`graphify-auto/\`)
<!-- @generated — regenerated by graphify on each commit via post-commit hook -->
Auto-generated knowledge graph nodes. Query via \`graphify query "<question>"\` rather than reading individual nodes.
<!-- /@generated -->

## Key Paths

| Path | Purpose |
|------|---------|
EOF
  echo "✓ created hub  $HUB"
else
  echo "• hub exists   $HUB (left as-is)"
fi

# Knowledge note: git-hook gotcha (idempotent)
NOTE="$VAULT/knowledge/git-hook-graphify.md"
if [ ! -f "$NOTE" ]; then
  cat > "$NOTE" <<EOF
---
tags:
  - gotcha
  - tooling
project: $PROJECT
date: $(date +%F)
format_version: "2.2.0"
---

# Git Hook: Auto-rebuild Graphify on Commit

See also: [[$PROJECT]]

$PROJECT has a post-commit (and post-checkout) git hook that rebuilds the graph automatically after every commit — a 0-token AST rebuild (equivalent to \`graphify update .\`) plus an Obsidian export. This keeps \`graphify-out/graph.json\` and the vault's \`graphify-auto/\` in sync with the code without manual intervention.

**Why this matters:** graphify's main risk is silent staleness (graph describes old structure). The commit hook removes this for normal work — the graph is current after every commit. One gap: a \`git pull\` is **not** a commit, so a fast-forward pull won't trigger a rebuild — run \`graphify update .\` (0 tokens) to resync after pulling someone else's changes.

> [!warning] If the hook stops firing
> Re-register with \`graphify hook install\` — needed after a fresh clone (hooks live in \`.git/hooks/\`, which isn't version-controlled) or a graphify upgrade.
EOF
  echo "✓ created knowledge note  $NOTE"
else
  echo "• knowledge note exists   $NOTE (left as-is)"
fi

# Home.md project link (idempotent) — insert as first item under "## Projects"
HOME_MD="$VAULT_BASE/Home.md"
if [ -f "$HOME_MD" ] && ! grep -q "Projects/$PROJECT/$PROJECT" "$HOME_MD"; then
  awk -v line="- [[Projects/$PROJECT/$PROJECT|$PROJECT]] — <one-line description>" '
    /^## Projects/ { inp=1; print; next }
    inp && NF && !done { print line; done=1; inp=0 }
    { print }
  ' "$HOME_MD" > "$HOME_MD.tmp" && mv "$HOME_MD.tmp" "$HOME_MD"
  echo "✓ linked project in Home.md"
else
  echo "• Home.md link present (or Home.md missing) — skipped"
fi

# 2. Install + patch the post-commit hook ----------------------------------
if [ ! -d "$REPO/.git" ]; then
  echo "⚠ $REPO is not a git repo — skipping hook install." >&2
else
  ( cd "$REPO" && graphify hook install ) >/dev/null 2>&1 \
    && echo "✓ graphify hook installed" \
    || echo "• graphify hook install returned non-zero (may already exist)"

  HOOK="$REPO/.git/hooks/post-commit"
  if [ ! -f "$HOOK" ]; then
    echo "⚠ no post-commit hook at $HOOK — run 'graphify hook install' manually." >&2
  elif grep -q '_obsidian_dir' "$HOOK"; then
    echo "• hook already exports to Obsidian"
  elif grep -q '_rebuild_code(' "$HOOK"; then
    # Snippet goes to a temp file; awk reads it with getline so embedded
    # newlines survive on BSD awk (macOS), which rejects newlines in -v vars.
    SNIP_TMP="$(mktemp)"
    cat > "$SNIP_TMP" <<PYEOF
    # graphify-obsidian-export (added by graphify-obsidian-init)
    import subprocess as _sp
    _obsidian_dir = '$AUTO_DIR'  # resolved from the vault base at scaffold time (via obsidian CLI; hook runs detached so the path is hardcoded here)
    _r = _sp.run([sys.executable, '-m', 'graphify', 'export', 'obsidian', '--dir', _obsidian_dir], cwd=str(_root), capture_output=True, text=True)
    print('[graphify hook] Obsidian vault updated -> ' + _obsidian_dir) if _r.returncode == 0 else print('[graphify hook] Obsidian export warning: ' + _r.stderr.strip())
PYEOF
    if awk -v snipfile="$SNIP_TMP" '
        { print }
        /_rebuild_code\(/ && !done {
          while ((getline ln < snipfile) > 0) print ln
          close(snipfile); done=1
        }
      ' "$HOOK" > "$HOOK.tmp"; then
      mv "$HOOK.tmp" "$HOOK"; chmod +x "$HOOK"
      echo "✓ patched hook → exports into Obsidian on each commit"
    else
      rm -f "$HOOK.tmp"
      echo "⚠ hook patch failed — patch manually (template Step 4)." >&2
    fi
    rm -f "$SNIP_TMP"
  else
    echo "⚠ no '_rebuild_code(' anchor in hook — patch manually (template Step 4)." >&2
  fi
fi

# 3. Next steps -------------------------------------------------------------
cat <<EOF

Next steps:
  1. Open Claude in $REPO and run:  /graphify
     (one-time initial build — includes semantic extraction of docs)
  2. Ensure 'graphify-out/' is in $REPO/.gitignore
  3. Commit anything, then verify:
       tail ~/.cache/graphify-rebuild.log
     should show:  Obsidian vault updated -> $AUTO_DIR

Done.
EOF
